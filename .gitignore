# --- Secrets (highest priority - never commit) ---
.env
.env.*
*.pem
*.key

# --- Python virtual environments ---
.venv/
venv/
env/

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Build artefacts / packaging ---
build/
dist/
*.egg-info/
*.egg

# --- SQLite databases (LCP will create one) ---
*.db
*.sqlite
*.sqlite3

# --- Editor / OS noise ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Logs ---
*.log